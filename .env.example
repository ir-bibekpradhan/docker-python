# Copy this file to .env and fill in values — never commit .env
APP_NAME=docker-python
APP_ENV=development

# Optional: proxy settings (used by pip during docker build)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# Optional: AWS credentials for boto3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Optional: Redis / MongoDB connection
# REDIS_URL=redis://localhost:6379/0
# MONGO_URI=mongodb://localhost:27017/mydb
